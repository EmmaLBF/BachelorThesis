    "version": "0.2.0",
    "configurations": [
        {
            "type": "ghc",
            "request": "launch",
            "name": "haskell(cabal)",
            "workspace": "${workspaceFolder}",
            "startup": "${workspaceFolder}/Main.hs",
            "startupFunc": "CLang2.main",
            "startupArgs": "",
            "stopOnEntry": false,
            "mainArgs": "",
            "ghciPrompt": "",
            "ghciInitialPrompt": "",
            "ghciCmd": "cabal repl -w ghci-dap",
            "ghciEnv": {},
            "logFile": "${workspaceFolder}/.vscode/phoityne.log",
            "logLevel": "DEBUG",
            "forceInspect": false
        }
    ]
}